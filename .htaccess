RewriteEngine On
RewriteBase /

# Map sitemap.xml to sitemap.php
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Redirect all requests that are not existing files or folders to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# --- Security Hardening ---
# Disable directory listing
Options -Indexes

# Block double extensions (e.g., shell.php.jpg)
RewriteCond %{REQUEST_URI} \.(php|phtml|php3|php4|php5|php7|phps)\.(jpg|jpeg|gif|png|bmp|webp|svg|ico|pdf|txt|doc|docx|xls|xlsx|ppt|pptx|zip|rar|tar|gz|7z)$ [NC]
RewriteRule .* - [F]

# Block access to private folders (Internal logic and config)
RewriteRule ^(include|view|config|admin/include)/.*$ - [F,L]

# Prevent access to sensitive files
<FilesMatch "\.(env|git|htaccess|htpasswd|ini|log|sh|bak|swp|orig|save)$">
	Order allow,deny
	Deny from all
</FilesMatch>

# Prevent access to backup/config files
<FilesMatch "(config|backup|db|mailer)\.(php|sql|bak|zip|tar|gz|7z)$">
	Order allow,deny
	Deny from all
</FilesMatch>

# Block development and setup scripts from public access
<FilesMatch "^(setup_|db_|check_|test_|debug_|seed_|scratch/).*\.php$">
	Order allow,deny
	Deny from all
</FilesMatch>
